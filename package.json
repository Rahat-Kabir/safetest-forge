{
  "name": "safetest-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "safetest-forge": "./src/cli.ts"
  },
  "scripts": {
    "build": "npm run build:ui && tsc --noEmit",
    "build:ui": "node scripts/build-ui.mjs",
    "cli": "tsx src/cli.ts",
